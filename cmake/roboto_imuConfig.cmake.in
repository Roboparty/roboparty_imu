@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(fmt)
find_dependency(spdlog)

include("${CMAKE_CURRENT_LIST_DIR}/roboto_imuTargets.cmake")

if(NOT TARGET roboto_imu::roboto_imu)
    add_library(roboto_imu::roboto_imu INTERFACE IMPORTED)
    target_link_libraries(roboto_imu::roboto_imu INTERFACE 
        roboto_imu::imu
        roboto_imu::hipnuc_imu
        roboto_imu::imu_protocol
    )
endif()

check_required_components(roboto_imu)
